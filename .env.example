# ── Dev mode ─────────────────────────────────────────────────────────────────
# Dev mode is automatic: if SUPABASE_URL is blank, auth is skipped entirely.
# To test auth locally, fill in SUPABASE_URL + SUPABASE_ANON_KEY below.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: leave as SQLite
# Production: paste Supabase connection string (Session mode, port 5432)
DATABASE_URL=sqlite:///./data/spendsense.db
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Keep SECRET — used by billing webhook

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys (sk_test_...) for local dev; swap for live keys in production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # From: Stripe dashboard → Webhooks → your endpoint
STRIPE_PRICE_ID_PRO=price_...            # Monthly recurring price ID for your Pro plan

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL of the Streamlit app — used for Stripe redirect and CORS
FRONTEND_URL=http://localhost:8501
# FRONTEND_URL=https://your-app.streamlit.app

# ── AI (Ollama) ───────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# ── Free tier limits ─────────────────────────────────────────────────────────
FREE_UPLOADS_PER_MONTH=3
FREE_TRANSACTIONS_MAX=100

# ── Server ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DATA_DIR=./data
